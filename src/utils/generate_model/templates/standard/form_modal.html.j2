{# Modal de formulário para {{ class_name }} — gerado automaticamente #}
<div class="modal fade" id="{{ class_name_lower }}Modal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="{{ class_name_lower }}ModalTitle">Novo {{ label }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="{{ class_name_lower }}Form">
          <input type="hidden" id="{{ class_name_lower }}Id">
          {{ form_fields }}
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" id="btnSave{{ class_name }}">Salvar</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const abortControllers = new Map();

    function getOrCreateDatalist(fieldName) {
      let datalist = document.getElementById(`datalist-${fieldName}`);
      if (!datalist) {
        datalist = document.createElement('datalist');
        datalist.id = `datalist-${fieldName}`;
        document.body.appendChild(datalist);
      }
      return datalist;
    }

    function setupForeignKeyField(container) {
      const fieldName = container.dataset.field;
      const foreignTable = container.dataset.foreignTable;
      const hiddenInput = container.querySelector('.fk-hidden-id');
      const searchInput = container.querySelector('.fk-search-input');
      const clearBtn = container.querySelector('.fk-clear-btn');

      const datalist = getOrCreateDatalist(fieldName);
      searchInput.setAttribute('list', datalist.id);

      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        hiddenInput.value = '';
        searchInput.focus();
      });

      let debounceTimer;
      searchInput.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        const query = e.target.value.trim();
        if (query.length < 2) { datalist.innerHTML = ''; return; }
        debounceTimer = setTimeout(() => loadOptions(query), 300);
      });

      async function loadOptions(search) {
        if (abortControllers.has(fieldName)) abortControllers.get(fieldName).abort();
        const controller = new AbortController();
        abortControllers.set(fieldName, controller);
        try {
          const url = `/api/options/${foreignTable}?search=${encodeURIComponent(search)}`;
          const response = await fetch(url, { signal: controller.signal });
          const data = await response.json();
          datalist.innerHTML = '';
          data.results.forEach(opt => {
            const option = document.createElement('option');
            option.value = opt.text;
            option.dataset.id = opt.id;
            datalist.appendChild(option);
          });
        } catch (err) {
          if (err.name === 'AbortError') return;
          console.error('Erro ao buscar opções:', err);
        } finally {
          abortControllers.delete(fieldName);
        }
      }

      searchInput.addEventListener('change', () => {
        const selected = Array.from(datalist.options).find(o => o.value === searchInput.value);
        hiddenInput.value = selected ? selected.dataset.id : '';
      });
    }

    window.setForeignKeyValue = function(modalId, fieldName, id, text) {
      const modal = document.getElementById(modalId);
      if (!modal) return;
      const container = modal.querySelector(`.fk-field[data-field="${fieldName}"]`);
      if (!container) return;
      const hidden = container.querySelector('.fk-hidden-id');
      const search = container.querySelector('.fk-search-input');
      if (hidden && search) { hidden.value = id; search.value = text || ''; }
    };

    const modalElement = document.getElementById('{{ class_name_lower }}Modal');
    if (modalElement) {
      modalElement.addEventListener('shown.bs.modal', function() {
        modalElement.querySelectorAll('.fk-field').forEach(setupForeignKeyField);
      });
    }
  })();
</script>